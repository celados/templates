{
	"name": "template-astro",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "astro dev --port 3000",
		"build": "SKIP_KEYSTATIC=true astro build",
		"preview": "astro preview",
		"preview:cf": "bun run build && wrangler dev",
		"check": "vp check && astro check",
		"deploy": "bun run build && wrangler deploy",
		"deploy:temporary": "bun run build && wrangler deploy --temporary"
	},
	"dependencies": {
		"@astrojs/markdoc": "^2.0.3",
		"@astrojs/react": "6.0.1",
		"@base-ui/react": "^1.6.0",
		"@fontsource-variable/inter": "^5.2.8",
		"@keystatic/astro": "^5.2.0",
		"@keystatic/core": "^0.5.51",
		"@tailwindcss/vite": "^4",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"astro": "7.0.7",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^1.24.0",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"shadcn": "^4.13.0",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^4",
		"tw-animate-css": "^1.4.0"
	},
	"devDependencies": {
		"@astrojs/check": "0.9.9",
		"@types/node": "^26.1.1",
		"typescript": "~6",
		"vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
		"vite-plus": "0.2.4",
		"wrangler": "^4.110.0"
	},
	"overrides": {
		"vite": "npm:@voidzero-dev/vite-plus-core@0.2.4"
	},
	"devEngines": {
		"packageManager": {
			"name": "bun",
			"version": "1.3.14",
			"onFail": "download"
		}
	},
	"engines": {
		"node": ">=22.12.0"
	}
}
